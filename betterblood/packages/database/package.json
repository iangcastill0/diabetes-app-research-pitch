{
  "name": "@bb/database",
  "version": "0.1.0",
  "description": "Database client and migrations for BetterBlood",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "seed": "node dist/seed.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "node-pg-migrate": "^6.2.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "^5.3.3"
  }
}